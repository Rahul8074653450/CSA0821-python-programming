# Given 2 integer arrays N1 and N2 , return an array of their intersection.
def array_intersection(N1, N2):
    set1 = set(N1)
    set2 = set(N2)
    result = list(set1.intersection(set2))
    return result
N1 = [1, 2, 2, 1]
N2 = [2, 2]
print("Intersection of arrays:", array_intersection(N1, N2))



